# ── Blog ingestion API (/api/blog) ─────────────────────────────────────────
# Shared secret n8n must send as:  Authorization: Bearer <token>
# (or header  x-api-key: <token> )
BLOG_INGEST_TOKEN=change-me-to-a-long-random-string

# Production persistence: the API commits new posts to content/blog/<slug>.md in
# your GitHub repo, and Vercel auto-redeploys to publish. Leave GITHUB_* empty to
# fall back to writing the file locally (dev only).
GITHUB_TOKEN=
GITHUB_OWNER=Makomest
GITHUB_REPO=privamesh-web
GITHUB_BRANCH=main

# Google Search Console verification (Settings → verification meta tag → content value)
GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (analytics.google.com → Admin → Data Streams)
NEXT_PUBLIC_GA_ID=
